# 本文件是配置模板 · 复制为 .env.local 后填入真实值
# .env.local 已被 .gitignore 忽略,不会提交到仓库

# 声网 · 从控制台「项目管理 → 测试项目」复制
AGORA_APP_ID=044f0fd2aa6846ac942fcab0e6321692

# 🔐 主要证书 · 绝密 · 从控制台「APP 证书 → 主要证书」复制
# 只能放在这里或 K8s Secret · 严禁提交到 git / 发聊天 / 粘贴到 LLM
AGORA_APP_CERT=

# Token 有效期 · 单位秒 · 默认 7200(2 小时)· 前端每 TTL-5min 会刷
AGORA_TOKEN_TTL=7200

# MySQL / Redis(本地 docker-compose 默认即可)
# MYSQL_HOST=localhost
# MYSQL_PASSWORD=
# REDIS_HOST=localhost
