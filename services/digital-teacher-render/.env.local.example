# ⚠️ 复制为 .env.local 填入真值 · .env.local 已 gitignored

# === Replicate(免费试用 $5)===
# 1. 注册 https://replicate.com/signin (用 GitHub 30 秒)
# 2. 头像 → API tokens → Create token
# 3. 粘贴下方
REPLICATE_API_TOKEN=

# === Adapter 路由 ===
# mock(默认 · 不发外网) · replicate · tencent_yinsu · heygen
ADAPTER_AVATAR=replicate
# mock · replicate · minimax · tencent_tts · elevenlabs
ADAPTER_TTS=replicate

# === Replicate 模型版本 · 可改成 fork 或 owner/model:version 锁版本 ===
REPLICATE_AVATAR_MODEL=cuuupid/musetalk
REPLICATE_TTS_MODEL=cjwbw/openvoice
